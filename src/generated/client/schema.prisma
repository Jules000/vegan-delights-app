generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

datasource db {
  provider = "postgresql"
}

model Product {
  id                String       @id @default(cuid())
  sku               String       @unique
  price             Float
  stock             Int          @default(0)
  productType       ProductType  @default(SHOP)
  category          String
  subcategory       String?
  isGlutenFree      Boolean      @default(false)
  nameFr            String
  nameEn            String
  descFr            String
  descEn            String
  image             String
  nutritionLabel1Fr String?
  nutritionLabel1En String?
  nutritionValue1   String?
  nutritionLabel2Fr String?
  nutritionLabel2En String?
  nutritionValue2   String?
  nutritionLabel3Fr String?
  nutritionLabel3En String?
  nutritionValue3   String?
  nutritionLabel4Fr String?
  nutritionLabel4En String?
  nutritionValue4   String?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  subcategoryId     String?
  bannerImage       String?
  bannerTextEn      String?
  bannerTextFr      String?
  menuDay           DayOfWeek?
  orderItems        OrderItem[]
  subcategoryRel    Subcategory? @relation(fields: [subcategoryId], references: [id])
}

model Order {
  id            String      @id @default(cuid())
  customerId    String
  status        String      @default("PENDING")
  txRef         String?     @unique
  paymentStatus String      @default("PENDING")
  total         Float
  deliveryFee   Float       @default(0)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  invoice       Invoice?
  customer      Customer    @relation(fields: [customerId], references: [id])
  items         OrderItem[]
}

model OrderItem {
  id              String  @id @default(cuid())
  orderId         String
  productId       String
  quantity        Int
  priceAtPurchase Float
  order           Order   @relation(fields: [orderId], references: [id])
  product         Product @relation(fields: [productId], references: [id])
}

model Customer {
  id                String    @id @default(cuid())
  email             String    @unique
  password          String?
  name              String
  totalSpent        Float     @default(0)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  isVerified        Boolean   @default(false)
  otp               String?
  otpExpires        DateTime?
  phone             String?   @unique
  resetToken        String?   @unique
  resetTokenExpires DateTime?
  role              UserRole  @default(CUSTOMER)
  invoices          Invoice[]
  orders            Order[]
}

model Invoice {
  id            String   @id @default(cuid())
  invoiceNumber String   @unique
  orderId       String   @unique
  customerId    String
  amount        Float
  status        String   @default("ISSUED")
  issuedAt      DateTime @default(now())
  customer      Customer @relation(fields: [customerId], references: [id])
  order         Order    @relation(fields: [orderId], references: [id])
}

model Subcategory {
  id          String      @id @default(cuid())
  nameFr      String
  nameEn      String
  slug        String      @unique
  productType ProductType
  order       Int         @default(0)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  products    Product[]
}

model Subscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
}

enum ProductType {
  RESTAURANT
  SHOP
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum UserRole {
  CUSTOMER
  ADMIN
}
